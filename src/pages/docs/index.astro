---
import Layout from "@/layouts/layout.astro";
import { TerminalBlock } from "@/components/terminal-block";
---

<Layout title="dither — docs" description="installation, usage, and api reference for the dither shadcn component.">
  <div class="min-h-screen bg-white">
    <div class="max-w-3xl mx-auto px-6 pt-16 pb-24">
      <!-- Page header -->
      <div class="mb-16">
        <a
          href="/docs/playground"
          class="group inline-flex items-center gap-1.5 border border-black/12 rounded-full px-3 py-1 mb-5 hover:border-black/30 transition-colors"
        >
          <span class="text-xs text-black/50 group-hover:text-black/70 transition-colors">try it out</span>
          <svg width="9" height="9" viewBox="0 0 10 10" fill="none" class="text-black/30 group-hover:text-black/60 group-hover:translate-x-px transition-all">
            <path d="M2 8L8 2M8 2H4M8 2V6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <h1 class="text-5xl font-bold tracking-tight text-black mb-4">
          dither
        </h1>
        <p class="text-lg text-black/40 max-w-xl leading-relaxed">
          a shadc/n canvas component that renders any image as a live,
          cursor-reactive dithered particle field. bayer matrix ordered
          dithering with spring physics.
        </p>
      </div>

      <!-- ── Installation ─────────────────────────────────────────────── -->
      <section class="mb-16">
        <h2 class="text-sm font-medium text-black/40 mb-6">installation</h2>

        <p class="text-sm text-black/50 mb-4">
          add the component to your project via the shadc/n cli:
        </p>

        <div class="mb-6">
          <TerminalBlock client:only="react" />
        </div>

        <p class="text-sm text-black/50 mb-4">
          this registers <code
            class="text-xs font-mono bg-black/5 px-1.5 py-0.5 rounded"
            >dither.tsx</code
          > into your
          <code class="text-xs font-mono bg-black/5 px-1.5 py-0.5 rounded"
            >components/</code
          > directory. no additional dependencies required — only react and a canvas-capable
          browser.
        </p>
      </section>

      <!-- ── Usage ────────────────────────────────────────────────────── -->
      <section class="mb-16">
        <h2 class="text-sm font-medium text-black/40 mb-6">usage</h2>

        <p class="text-sm text-black/50 mb-4">
          wrap the component in a sized container — the canvas fills 100% width
          and height.
        </p>

        <div class="rounded-xl bg-black overflow-hidden mb-6">
          <div
            class="flex items-center justify-between px-4 py-3 border-b border-white/8"
          >
            <span class="text-xs font-medium text-white/30">example.tsx</span>
          </div>
          <pre
            class="px-4 py-5 text-xs font-mono text-white/70 leading-relaxed overflow-x-auto"><span class="text-white/30">import</span> <span class="text-white/80">{"{ Dither }"}</span> <span class="text-white/30">from</span> <span class="text-white/60">"@/components/dither"</span>;

<span class="text-white/30">export default function</span> <span class="text-white/80">App</span>() {"{"}
  <span class="text-white/30">return</span> (
    <span class="text-white/60">&lt;div</span> <span class="text-white/40">className</span>=<span class="text-white/60">"w-64 h-64"</span><span class="text-white/60">&gt;</span>
      <span class="text-white/60">&lt;Dither</span>
        <span class="text-white/40">src</span>=<span class="text-white/60">"/my-image.png"</span>
        <span class="text-white/40">pixelSize</span>={"{"}2{"}"}
        <span class="text-white/40">colorFilter</span>=<span class="text-white/60">"invert"</span>
        <span class="text-white/40">pixelShape</span>=<span class="text-white/60">"circle"</span>
      <span class="text-white/60">/&gt;</span>
    <span class="text-white/60">&lt;/div&gt;</span>
  );
{"}"}</pre>
        </div>

        <div class="rounded-xl border border-black/8 p-5 bg-black/[0.01]">
          <p class="text-xs text-black/40 font-medium mb-2">
            transparent background tip
          </p>
          <p class="text-sm text-black/50 leading-relaxed">
            use <code class="text-xs font-mono bg-black/5 px-1 py-0.5 rounded"
              >transparentColor</code
            > to knock out a background colour so only the subject floats as particles.
            works well with icons or logos on white/black backgrounds.
          </p>
          <pre
            class="mt-3 text-xs font-mono text-black/40 leading-relaxed bg-black/3 rounded-lg px-3 py-2.5">{"<Dither\n  src=\"/icon.png\"\n  transparentColor=\"#ffffff\"\n  euclideanDistance={40}\n/>"}</pre>
        </div>
      </section>

      <!-- ── API ──────────────────────────────────────────────────────── -->
      <section class="mb-16">
        <h2 class="text-sm font-medium text-black/40 mb-6">api</h2>

        <div class="border border-black/8 rounded-xl overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-black/6 bg-black/[0.015]">
                <th
                  class="text-left px-4 py-3 text-xs font-medium text-black/40 w-36"
                  >prop</th
                >
                <th
                  class="text-left px-4 py-3 text-xs font-medium text-black/40 w-28"
                  >type</th
                >
                <th
                  class="text-left px-4 py-3 text-xs font-medium text-black/40 w-20"
                  >default</th
                >
                <th
                  class="text-left px-4 py-3 text-xs font-medium text-black/40"
                  >description</th
                >
              </tr>
            </thead>
            <tbody class="divide-y divide-black/5">
              {
                [
                  { prop: "src", type: "string", def: "—", desc: "image url. required." },
                  { prop: "pixelSize", type: "number", def: "2", desc: "width & height of each dot in px." },
                  { prop: "gap", type: "number", def: "1", desc: "space between dots in px." },
                  { prop: "noise", type: "number", def: "0.4", desc: "jitter on dot home positions (0–1). reduces moiré patterns." },
                  { prop: "pixelShape", type: "PixelShape", def: '"circle"', desc: '"circle" | "square" | "triangle"' },
                  { prop: "cursorRadius", type: "number", def: "50", desc: "inner dead-zone radius — pixels inside are strongly repelled." },
                  { prop: "outerRadius", type: "number", def: "150", desc: "furthest cursor influence. force fades to zero at this distance." },
                  { prop: "cursorStrength", type: "number", def: "6", desc: "magnitude of the cursor push force." },
                  { prop: "spring", type: "number", def: "0.06", desc: "spring stiffness controlling how fast pixels return home." },
                  { prop: "damping", type: "number", def: "0.82", desc: "velocity multiplier per frame. higher = less bounce." },
                  { prop: "colorFilter", type: "ColorFilter", def: '"none"', desc: '"none" | "invert" | "grayscale" | "sepia" | (r,g,b)=>[r,g,b]' },
                  { prop: "transparentColor", type: "string | RGBColor", def: "—", desc: "color to treat as transparent (hex string or [r,g,b] tuple)." },
                  { prop: "euclideanDistance", type: "number", def: "30", desc: "rgb distance threshold used with transparentColor." },
                  { prop: "padding", type: "number", def: "outerRadius", desc: "canvas padding (px) so edge pixels have room to scatter." },
                  { prop: "className", type: "string", def: "—", desc: "passed to the <canvas> element." },
                  { prop: "style", type: "CSSProperties", def: "—", desc: "passed to the <canvas> element." },
                ].map((row) => (
                  <tr class="hover:bg-black/[0.012] transition-colors">
                    <td class="px-4 py-3 font-mono text-xs text-black/70">{row.prop}</td>
                    <td class="px-4 py-3 font-mono text-xs text-black/35">{row.type}</td>
                    <td class="px-4 py-3 font-mono text-xs text-black/35">{row.def}</td>
                    <td class="px-4 py-3 text-xs text-black/50 leading-relaxed">{row.desc}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <!-- Types -->
        <div class="mt-6 rounded-xl bg-black overflow-hidden">
          <div class="px-4 py-3 border-b border-white/8">
            <span class="text-xs font-medium text-white/30">types</span>
          </div>
          <pre
            class="px-4 py-5 text-xs font-mono text-white/60 leading-relaxed overflow-x-auto"><span class="text-white/30">type</span> <span class="text-white/80">PixelShape</span>     = <span class="text-white/55">"circle" | "square" | "triangle"</span>;
<span class="text-white/30">type</span> <span class="text-white/80">ColorFilterPreset</span> = <span class="text-white/55">"none" | "invert" | "grayscale" | "sepia"</span>;
<span class="text-white/30">type</span> <span class="text-white/80">ColorFilterFn</span>  = <span class="text-white/55">(r: number, g: number, b: number) =&gt; [number, number, number]</span>;
<span class="text-white/30">type</span> <span class="text-white/80">ColorFilter</span>    = <span class="text-white/80">ColorFilterPreset</span> <span class="text-white/30">|</span> <span class="text-white/80">ColorFilterFn</span>;
<span class="text-white/30">type</span> <span class="text-white/80">RGBColor</span>       = <span class="text-white/55">[number, number, number]</span>;</pre>
        </div>
      </section>

    </div>
  </div>
</Layout>
